# FastAPI
APP_NAME=M5 Forecast Service
APP_DESCRIPTION=Сервис прогнозирования спроса на скоропортящиеся товары
API_VERSION=1.0.0
DEBUG=true

# JWT
SECRET_KEY=your_super_secret_key_change_in_production_12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cookie
COOKIE_NAME=access_token

# PostgreSQL (для FastAPI)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=m5_forecast

# PostgreSQL (для Docker Compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=m5_forecast

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rmuser
RABBITMQ_PASS=rmpassword
RABBITMQ_QUEUE=m5_forecast_tasks

# ML Worker
MODEL_PATH=./model/artifacts/model.pkl
ALPHA=0.2
HORIZON_DAYS=28

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
